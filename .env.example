# AetherOS Environment Configuration
# Copy this to .env and update values for your environment

# ============================================
# DATABASE
# ============================================
# MongoDB connection URI
MONGO_URI=mongodb://127.0.0.1:27017/aetheros

# ============================================
# CACHE (Redis)
# ============================================
# Redis connection URL
# Local development (default)
REDIS_URL=redis://127.0.0.1:6379

# With authentication
# REDIS_URL=redis://username:password@host:6379

# Redis Cloud (production)
# REDIS_URL=rediss://token:password@host:port

# ============================================
# SERVER
# ============================================
# Server port (default: 4000)
PORT=4000

# ============================================
# AZURE (Optional)
# ============================================
# Azure Cosmos DB
AZURE_COSMOSDB_CONNECTION_STRING=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_VERSION=2024-02-15-preview

# ============================================
# GITHUB (Optional)
# ============================================
# GitHub Personal Access Token for repository analysis
GITHUB_TOKEN=

# ============================================
# NODE ENVIRONMENT
# ============================================
# development | production
NODE_ENV=development
