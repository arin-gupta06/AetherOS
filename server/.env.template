# AetherOS Azure Integration - Environment Configuration Template
# Copy this file to server/.env and fill in your credentials

# ==========================================
# Azure OpenAI Configuration
# ==========================================
# Required for: Architecture analysis, deployment suggestions, scalability analysis

# Your Azure OpenAI API Key
# Get from: Azure Portal → Azure OpenAI Service → Keys and Endpoint
AZURE_OPENAI_KEY=your-azure-openai-api-key-here

# Your Azure OpenAI Endpoint
# Format: https://{resource-name}.openai.azure.com/
# Get from: Azure Portal → Azure OpenAI Service → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Deployment name of your model in Azure OpenAI
# Common values: gpt-35-turbo, gpt-4, gpt-4-turbo
# Get from: Azure Portal → Azure OpenAI Studio → Deployments
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-35-turbo


# ==========================================
# GitHub API Configuration (Optional)
# ==========================================
# Without this: Limited to public API rate limits (60 requests/hour per IP)
# With this: 5,000 requests/hour per authenticated user

# Your GitHub Personal Access Token
# Get from: GitHub Settings → Developer Settings → Personal access tokens
# Required scopes: public_repo, repo
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-personal-access-token-here


# ==========================================
# Database Configuration (Optional)
# ==========================================
# The system runs in memory-only mode if MongoDB is not available
# Leave commented out to use memory-only mode, or configure MongoDB

# MongoDB Connection URI
# Format: mongodb://[username:password@]hostname[:port]/database
# Example: mongodb://127.0.0.1:27017/aetheros
# MONGO_URI=mongodb://127.0.0.1:27017/aetheros


# ==========================================
# Server Configuration
# ==========================================
# Port to run the AetherOS backend on
PORT=4000

# Node environment
NODE_ENV=development

# Enable debug logging (optional)
DEBUG=aetheros:*


# ==========================================
# Quick Setup Instructions
# ==========================================
# 
# 1. Create server/.env file:
#    cp server/.env.template server/.env
#
# 2. Get Azure OpenAI credentials:
#    - Go to https://portal.azure.com
#    - Create or select Azure OpenAI Service resource
#    - Navigate to Keys and Endpoint
#    - Copy API key and save to AZURE_OPENAI_KEY
#    - Copy endpoint URL and save to AZURE_OPENAI_ENDPOINT
#
# 3. (Optional) Get GitHub Token:
#    - Go to https://github.com/settings/tokens/new
#    - Give it a name like "AetherOS"
#    - Select scopes: public_repo, repo
#    - Copy and save to GITHUB_TOKEN
#
# 4. Start the application:
#    npm run dev
#
# If configured correctly, Azure features will be available:
# - Architecture analysis via Azure OpenAI ✅
# - GitHub repository analysis ✅
# - Reference architecture templates ✅
# - AI-powered deployment suggestions ✅
# - Scalability analysis ✅
#
# ==========================================
